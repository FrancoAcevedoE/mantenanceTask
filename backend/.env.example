# Copiá este archivo a .env y completá los valores REALES antes de correr el servidor

# MongoDB
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/mantenanceDB

# JWT — generá un secreto largo y aleatorio: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# Orígenes permitidos (separados por coma)
CORS_ORIGINS=https://tu-app.vercel.app

# Notificaciones push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@email.com

# Entorno
NODE_ENV=production
PORT=3000
