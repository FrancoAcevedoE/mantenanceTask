# VITE_API_BASE_URL no se define acá — cada entorno tiene su propio proxy:
#   Dev:  vite.config.js proxy /api → http://localhost:3000
#   Prod: vercel.json rewrite /api/* → https://mantenancedb-backend.onrender.com/api/$1
# Si se define acá, el valor queda compilado en el bundle y rompe producción.
# VITE_API_BASE_URL=https://mantenancedb-backend.onrender.com

# URL pública de la PWA (la que abre el QR / "Abrir enlace directo" en el login)
VITE_PWA_URL=https://mantenance-task-francoacevedoes-projects.vercel.app